{:paths ["src"]
 :deps {org.clojure/clojure {:mvn/version "1.12.1"}

        ;; hive-dsl — Result monad (r/ok, r/err, r/bind, r/let-ok, r/try-effect).
        ;; CPPB threads Results through promoters via r/bind; Result is the only
        ;; non-Clojure-core dep of the macro layer.
        io.github.hive-agi/hive-dsl {:mvn/version "0.5.2"}

        ;; test.check — required by hive-cppb.test, which lives on :paths ["src"]
        ;; and therefore ships in the jar as public API (the property-based
        ;; scaffolding for the CPPB role laws). It has to be a main dep, not a
        ;; :test-alias dep, or consumers requiring hive-cppb.test hit
        ;; FileNotFoundException on clojure/test/check.
        org.clojure/test.check {:mvn/version "1.1.1"}}

 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps {io.github.cognitect-labs/test-runner
                {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                org.clojure/test.check {:mvn/version "1.1.1"}}
   :main-opts ["-m" "cognitect.test-runner"]}

  :build
  {:deps {io.github.clojure/tools.build {:mvn/version "0.10.9"}
          slipset/deps-deploy {:mvn/version "0.2.2"}}
   :ns-default build}}}
